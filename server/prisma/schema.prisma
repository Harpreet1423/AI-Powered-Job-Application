generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("seeker") // seeker, recruiter, admin
  avatar    String?
  bio       String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs           Job[]
  applications   Application[]
  savedJobs      SavedJob[]
  resumeAnalyses ResumeAnalysis[]
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String // remote, onsite, hybrid
  type        String // full-time, part-time, contract
  salaryMin   Int?
  salaryMax   Int?
  description String
  skills      String // comma-separated
  deadline    DateTime?
  status      String   @default("active") // active, paused, closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recruiterId String
  recruiter   User          @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  applications Application[]
  savedBy     SavedJob[]
}

model Application {
  id          String   @id @default(cuid())
  resumeUrl   String?
  coverLetter String?
  status      String   @default("pending") // pending, reviewed, interview, accepted, rejected
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seekerId String
  seeker   User   @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@unique([jobId, seekerId])
}

model SavedJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model ResumeAnalysis {
  id        String   @id @default(cuid())
  resumeUrl String
  atsScore  Int
  feedback  String // JSON string
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
